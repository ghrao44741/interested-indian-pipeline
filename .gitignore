# Generated media — large, binary, fully regenerable from manifest.json +
# source_audio + the pipeline scripts in shorts_pipeline2/. Not worth
# tracking in git; back these up separately (e.g. Drive) if needed.
*/audio/*
!*/audio/.gitkeep

*/source_audio/*
!*/source_audio/.gitkeep

*/images/*
!*/images/.gitkeep

*/videos/*
!*/videos/.gitkeep

*/output/*
!*/output/.gitkeep

# Secrets / credentials — never commit these
.env
Youtube_Interested_Indian_Upload.json
*_Upload.json
google_credentials*.json
token.json

# BGM / audio assets (large media — store separately)
bgm.mp3
ep01/bgm.mp3
ep01/bgm_orig.mp3
common/cta/*.mp3

# Large GeoJSON data files (one-time download, not code)
*.geojson

# Manifest backups (noise — keep only current manifest.json)
ep01/manifest_backup_*.json

# OS / editor cruft
__pycache__/
*.pyc
.DS_Store
Thumbs.db
